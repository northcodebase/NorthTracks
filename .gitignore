# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs (regenerated by npm run build) ──────────────────────────────
dist/

# ── Packaged installer output (regenerated by npm run build:win) ──────────────
# The .exe is uploaded to GitHub Releases, not committed to the repo.
dist-release/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
