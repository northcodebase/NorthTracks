{
  "name": "northtracks",
  "productName": "NorthTracks",
  "version": "1.1.0",
  "description": "NorthTracks - Your personal music library manager",
  "author": "NorthCodeBase",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
