    "discord-rpc": "^4.0.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.395.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "allowScripts": {
    "lzma-native@8.0.6": true,
    "electron": true,
    "esbuild": true
